// =============================================================
//  settings.typ — Оформление по ГОСТ 7.32-2017 и ГОСТ 2.105-2019
//
//  ВАЖНО (архитектура Typst):
//  `set` и `show` правила работают только когда они находятся
//  непосредственно в теле функции, применяемой через `#show: fn`.
//  Вынос в отдельные вспомогательные функции и их вызов через ()
//  создаёт изолированный скоуп — правила не пробрасываются наружу.
//  Поэтому ВСЕ правила прописаны инлайн внутри `apply-gost`.
// =============================================================


// =============================================================
//  ГЛАВНАЯ ФУНКЦИЯ — применяется через `#show: apply-gost`
// =============================================================
#let apply-gost(body) = {

  // -----------------------------------------------------------
  //  1. СТРАНИЦА  (ГОСТ 7.32 §5.1)
  //  Поля: лево 30 мм, право 15 мм, верх 20 мм, низ 20 мм
  // -----------------------------------------------------------
  set page(
    paper:        "a4",
    margin:       (left: 30mm, right: 15mm, top: 20mm, bottom: 20mm),
    numbering:    "1",
    number-align: center + bottom,
  )

  // -----------------------------------------------------------
  //  2. ОСНОВНОЙ ТЕКСТ  (ГОСТ 7.32 §6.2)
  //  Times New Roman 14 пт, интервал 1.5, отступ 1.25 см
  // -----------------------------------------------------------
  set text(
    font:      ("Times New Roman", "FreeSerif", "Liberation Serif"),
    size:      14pt,
    lang:      "ru",
    hyphenate: true,
  )

  set par(
    justify:           true,
    leading:           0.75em,
    spacing:           1.5em,
    first-line-indent: (amount: 1.25cm, all: true),
  )

  // -----------------------------------------------------------
  //  3. ЗАГОЛОВКИ  (ГОСТ 7.32 §6.3)
  //  H1 — по центру, прописные, жирный
  //  H2 — влево, жирный
  //  H3 — влево, жирный курсив
  // -----------------------------------------------------------
  set heading(numbering: "1.1.")

  show heading.where(level: 1): it => {
    v(2em, weak: true)
    align(center)[
      #text(size: 14pt, weight: "bold")[#upper(it.body)]
    ]
    v(1em, weak: true)
  }

  show heading.where(level: 2): it => {
    v(2em, weak: true)
    text(size: 14pt, weight: "bold")[#it.body]
    v(1em, weak: true)
  }

  show heading.where(level: 3): it => {
    v(1.5em, weak: true)
    text(size: 14pt, weight: "bold", style: "italic")[#it.body]
    v(0.75em, weak: true)
  }

  // -----------------------------------------------------------
  //  4. ОГЛАВЛЕНИЕ  (ГОСТ 7.32 §6.4)
  //  Записи первого уровня — жирные
  // -----------------------------------------------------------
  show outline.entry.where(level: 1): it => {
    v(4pt, weak: true)
    strong(it)
  }

  // -----------------------------------------------------------
  //  5. СПИСКИ  (ГОСТ 7.32 §6.5)
  //  Маркер — тире (—), нумерация — арабские цифры с точкой
  // -----------------------------------------------------------
  set list(
    marker:  ([—], [–], [·]),
    indent:  1.25cm,
    spacing: 0.5em,
  )

  set enum(
    numbering: "1.",
    indent:    1.25cm,
    spacing:   0.5em,
  )

  // -----------------------------------------------------------
  //  6. РИСУНКИ  (ГОСТ 7.32 §6.8)
  //  «Рисунок N — Название» под рисунком, по центру, 12 пт
  // -----------------------------------------------------------
  show figure.where(kind: image): it => {
    v(0.5em)
    align(center, it.body)
    v(0.25em)
    align(center,
      text(size: 12pt)[Рисунок #it.counter.display() — #it.caption.body]
    )
    v(0.5em)
  }

  // -----------------------------------------------------------
  //  7. ТАБЛИЦЫ  (ГОСТ 7.32 §6.9 и ГОСТ 2.105-2019)
  //  «Таблица N — Название» над таблицей, влево, 12 пт
  //  Заголовок таблицы — жирный
  // -----------------------------------------------------------
  show figure.where(kind: table): it => {
    v(0.5em)
    align(left,
      text(size: 12pt)[Таблица #it.counter.display() — #it.caption.body]
    )
    v(0.25em)
    it.body
    v(0.5em)
  }

  set table(
    stroke: 0.5pt + black,
    inset:  6pt,
    align:  center + horizon,
  )

  show table.cell.where(y: 0): strong

  // -----------------------------------------------------------
  //  8. СНОСКИ
  // -----------------------------------------------------------
  set footnote.entry(
    separator: line(length: 40%, stroke: 0.5pt),
  )

  show footnote.entry: set text(size: 10pt)

  // -----------------------------------------------------------
  //  9. БИБЛИОГРАФИЯ  (ГОСТ Р 7.0.100-2018)
  // -----------------------------------------------------------
  set bibliography(
    style: "gost-r-705-2008-numeric",
    title: [#upper[Список использованных источников]],
  )

  show bibliography: set text(size: 14pt)

  // -----------------------------------------------------------
  //  10. КОД / ЛИСТИНГИ
  // -----------------------------------------------------------
  show raw.where(block: true): it => {
    block(
      width:  100%,
      inset:  8pt,
      radius: 3pt,
      fill:   luma(245),
      stroke: 0.5pt + luma(180),
      text(font: ("Courier New", "DejaVu Sans Mono"), size: 11pt, it),
    )
  }

  show raw.where(block: false): it => {
    text(font: ("Courier New", "DejaVu Sans Mono"), size: 12pt, it)
  }

  // -----------------------------------------------------------
  //  Тело документа
  // -----------------------------------------------------------
  body
}


// =============================================================
//  ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
// =============================================================

// -------------------------------------------------------------
//  Титульный лист
//  Использует page() для изоляции настроек одной страницы —
//  на ней не отображается номер (ГОСТ 7.32 §6.1)
// -------------------------------------------------------------
#let title-page(
  ministry:         [Министерство / Корпорация],
  university:       [Название учебного заведения],
  department:       [Кафедра / подразделение],
  topic:            [Тема реферата],
  discipline:       [Наименование дисциплины],
  author:           [Иванов И.И.],
  group:            [Группа 000],
  supervisor:       [Петров П.П.],
  supervisor-title: [Руководитель],
  city:             [Москва],
  year:             [2025],
) = {
  // page() создаёт ровно одну страницу с нужными настройками
  page(numbering: none)[
    #align(center)[
      #v(0.5em)
      #text(size: 14pt)[#ministry]
      #v(0.5em)
      #text(size: 14pt)[#university]
      #v(0.5em)
      #text(size: 14pt)[#department]
      #v(4em)
      #text(size: 14pt, weight: "bold")[РЕФЕРАТ]
      #v(0.5em)
      #text(size: 14pt)[по дисциплине: #discipline]
      #v(1em)
      #text(size: 16pt, weight: "bold")[#topic]
    ]

    #v(3em)

    #grid(
      columns: (1fr, 1fr),
      [],
      align(left)[
        #text(size: 14pt)[
          #supervisor-title: #supervisor \
          #v(0.5em)
          Выполнил(а): #author \
          #group
        ]
      ],
    )

    #v(1fr)

    #align(center)[
      #text(size: 14pt)[#city, #year]
    ]
  ]

  // Титул считается стр. 1, следующая будет стр. 2
  counter(page).update(2)
}


// -------------------------------------------------------------
//  Оглавление
//  Заголовок «СОДЕРЖАНИЕ» по ГОСТу — прописными, по центру
// -------------------------------------------------------------
#let contents() = {
  outline(
    title: align(center)[
      #text(weight: "bold", size: 14pt)[#upper[Содержание]]
    ],
    indent: auto,
    depth:  3,
  )
  pagebreak()
}


// -------------------------------------------------------------
//  Ненумерованный раздел (Введение, Заключение)
//  Попадает в оглавление, но без номера раздела
// -------------------------------------------------------------
#let unnumbered-section(title) = {
  heading(numbering: none)[#upper(title)]
}
